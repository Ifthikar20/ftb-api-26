{
    "gateway": {
        "port": 18789,
        "host": "0.0.0.0",
        "auth": {
            "token": "${OPENCLAW_AUTH_TOKEN}"
        },
        "endpoints": {
            "responses": true,
            "chat_completions": false
        }
    },
    "models": {
        "default": {
            "provider": "anthropic",
            "model": "claude-sonnet-4-20250514",
            "api_key": "${ANTHROPIC_API_KEY}"
        }
    },
    "memory": {
        "enabled": true,
        "backend": "sqlite",
        "path": "/home/user/.openclaw/memory.db"
    },
    "skills": {
        "directories": [
            "/home/user/.openclaw/skills"
        ]
    }
}