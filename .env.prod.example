# ═══════════════════════════════════════════════════════
#  FetchBot — Production Environment Variables
#  Copy to .env.prod and fill in real values
# ═══════════════════════════════════════════════════════

# ── Django ──
DJANGO_SECRET_KEY=CHANGE_ME_USE_50_CHAR_RANDOM_STRING
DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=False
ALLOWED_HOSTS=fetchbot.ai,www.fetchbot.ai

# ── Database (internal Docker network) ──
DB_NAME=growthpilot
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_HOST=db
DB_PORT=5432

# ── Redis (internal Docker network) ──
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ── JWT ──
JWT_SIGNING_KEY=CHANGE_ME_USE_64_CHAR_RANDOM_STRING

# ── Field Encryption ──
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=CHANGE_ME

# ── CORS ──
CORS_ALLOWED_ORIGINS=https://fetchbot.ai,https://www.fetchbot.ai

# ── External Services ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_SCALE_PRICE_ID=
STRIPE_STARTER_ANNUAL_PRICE_ID=
STRIPE_GROWTH_ANNUAL_PRICE_ID=
STRIPE_SCALE_ANNUAL_PRICE_ID=
SENDGRID_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
SENTRY_DSN=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── AWS S3 (for media/static storage) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=fetchbot-assets
AWS_S3_REGION_NAME=us-east-1

# ── Email ──
OPS_EMAIL=ops@fetchbot.ai
SERVER_EMAIL=noreply@fetchbot.ai
