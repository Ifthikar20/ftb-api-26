# ── Django ──
DJANGO_SECRET_KEY=change-me-in-production-use-50-char-random-string
DJANGO_SETTINGS_MODULE=config.settings.dev
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──
DB_NAME=growthpilot
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ── JWT ──
JWT_SIGNING_KEY=change-me-use-64-char-random-string-in-production

# ── Field Encryption (Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ──
FIELD_ENCRYPTION_KEY=

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── External Services ──
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_SCALE_PRICE_ID=price_...
SENDGRID_API_KEY=SG....
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
SENTRY_DSN=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ── AWS (production only) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=growthpilot-assets
AWS_S3_REGION_NAME=us-east-1

# ── Email ──
OPS_EMAIL=ops@growthpilot.io
SERVER_EMAIL=noreply@growthpilot.io

# ── Integration Credentials ──
# HubSpot CRM
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Semrush (competitor intelligence)
SEMRUSH_API_KEY=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Mailchimp (outbound email campaigns)
# Get from: Mailchimp Account -> Extras -> API Keys
MAILCHIMP_API_KEY=

# Google Drive (lead exports to Google Sheets)
# Uses same OAuth credentials as GA/GSC above — no separate key needed
# Just ensure GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET are set

# Canva (design link integration)
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# OpenClaw AI Agent Gateway (optional — enables real LinkedIn/X scraping for lead finder)
OPENCLAW_GATEWAY_URL=
OPENCLAW_AUTH_TOKEN=

# ── LLM Ranking (Generative Engine Optimization) ──
# Measures how often your business appears when users ask LLMs to find you.
# Claude uses ANTHROPIC_API_KEY above — no separate key needed.

# OpenAI GPT-4 (https://platform.openai.com/api-keys)
# OPENAI_API_KEY already set above

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Perplexity (https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=
